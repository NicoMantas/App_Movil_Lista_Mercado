<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShopList"
        tools:targetApi="36">

        <!-- Pantalla de inicio (LAUNCHER) -->
        <activity
            android:name=".SplashActivityCompose"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pantallas en Compose -->
        <activity android:name=".LoginActivityCompose" />
        <activity android:name=".RegisterActivityCompose" />
        <activity android:name=".RecoverPasswordActivityCompose" />
        <activity android:name=".HomeActivityCompose" />
        <activity android:name=".CreateListActivityCompose" />
        <activity android:name=".AddProductActivityCompose" />
        <activity android:name=".EditProductActivityCompose" />
        <activity android:name=".ListDetailsActivityCompose" />
        <activity android:name=".CreditsActivityCompose" />

    </application>

</manifest>